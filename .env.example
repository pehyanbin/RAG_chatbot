# Server
RAG_DB_PATH=rag.sqlite3

# Choose:
# openai_api_key, openai_compatible_api, nvidia_nim_api, ollama_api,
# openrouter_api, gemini_api_key, anthropic_api_key, deepseek_api,
# xai_api, moonshot_ai, codex_oauth, openai_plus_pro_subscription,
# gemini_cli_oauth, google_antigravity_oauth, opencode
LLM_PROVIDER=ollama_api

# Generation controls
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=900

# Ollama default
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Generic OpenAI-compatible
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=RAG Agent Starter

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# xAI
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4

# Moonshot / Kimi
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_MODEL=kimi-k2-0905-preview

# Local CLI/OAuth bridge.
# These commands receive the final RAG prompt over STDIN.
CODEX_COMMAND_JSON=["codex","exec"]
GEMINI_CLI_COMMAND_JSON=["gemini","-p"]
ANTIGRAVITY_COMMAND_JSON=["gemini","-p"]
OPENCODE_COMMAND_JSON=["opencode","run"]

# Embeddings:
# hash, local_sentence_transformers, openai_compatible, gemini
EMBEDDING_PROVIDER=hash
EMBEDDING_DIM=512

# OpenAI-compatible embeddings
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Gemini embeddings
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Local high-quality embeddings. First run downloads the model.
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# vector, keyword, hybrid
RETRIEVAL_MODE=hybrid
